<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ page_title }}</title>
<link rel="stylesheet" href="../assets/style.css">
</head>
<body class="page-summary">

<a class="back-link" href="../index.html">&larr; Back to Career Arc</a>

<h1>{{ title | safe }}</h1>

<div class="meta">
  <p><strong>Authors:</strong> {{ authors_html }}{% if authors_affiliation %} ({{ authors_affiliation }}){% endif %}</p>
  {% if venue %}<p><strong>Venue:</strong> {{ venue | safe }}</p>{% endif %}
  {% if paper_number %}<p><strong>Paper number:</strong> {{ paper_number }}</p>{% endif %}
  {% if doi %}<p><strong>DOI:</strong> <a href="https://doi.org/{{ doi }}">{{ doi }}</a></p>{% endif %}
  {% if funding %}<p><strong>Funding:</strong> {{ funding }}</p>{% endif %}
  {% for m in extra_meta or [] %}<p><strong>{{ m.label }}:</strong> {{ m.value_html | safe }}</p>
  {% endfor %}
  <p><strong>Citations{% if citations_source %} ({{ citations_source }}){% endif %}:</strong> {{ citations if citations is not none else 'not catalogued' }}{% if citations_note %}, {{ citations_note }}{% endif %}</p>
  <p>{% if landmark_inline_text %}<span class="landmark-inline">{{ landmark_inline_text | safe }}</span> {% endif %}{% for tag in tags %}<span class="tag">{{ tag | safe }}</span> {% endfor %}</p>
</div>
{% if landmark %}
<div class="landmark">
{{ landmark_html | safe }}
</div>
{% endif %}
{% for section in sections %}
<h2>{{ section.heading }}</h2>
{% if section.box_style %}<div class="{{ section.box_style }}">
{{ section.body_html | safe }}
</div>
{% else %}
{{ section.body_html | safe }}
{% endif %}
{% endfor %}

<a class="back-link" href="../index.html" style="display:inline-block;margin-top:30px;">&larr; Back to Career Arc</a>

</body>
</html>
